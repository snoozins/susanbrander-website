<section aria-label="Introduction" class="pt-20 pb-16 sm:pt-28 sm:pb-20">
  <div class="mx-auto max-w-[680px] px-6 sm:px-8">
    <h1 class="font-display text-5xl sm:text-6xl font-bold tracking-tight">
      Susan Brander
    </h1>

    <p class="mt-5 font-display text-xl sm:text-2xl italic" style="color: var(--color-accent-border)">
      Technical depth. Human-first leadership.
    </p>

    <p class="mt-6 text-base sm:text-lg leading-relaxed max-w-[560px]" style="color: var(--color-ink-muted)">
      CTO at Kaleida. Founder of Tech Leading Ladies. Conference speaker on engineering
      leadership, continuous improvement, and building cultures where everyone can do their
      best work.
    </p>

    <div class="mt-9 flex flex-wrap gap-3" role="list">
      <a
        href="https://www.linkedin.com/in/susan-brander/"
        target="_blank"
        rel="noopener noreferrer"
        role="listitem"
        class="btn-primary inline-flex items-center px-5 py-2.5 rounded-md font-medium text-sm text-white no-underline hover:no-underline transition-colors"
      >
        Connect on LinkedIn
      </a>
      <a
        href="#speaking"
        role="listitem"
        class="btn-secondary inline-flex items-center px-5 py-2.5 rounded-md font-medium text-sm no-underline hover:no-underline border transition-colors"
      >
        View speaking &darr;
      </a>
    </div>
  </div>
</section>

<style>
  .btn-primary {
    background-color: var(--color-accent);
    color: white;
  }
  .btn-primary:hover {
    background-color: var(--color-accent-hover);
  }
  .btn-secondary {
    color: var(--color-ink);
    border-color: var(--color-border);
  }
  .btn-secondary:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
