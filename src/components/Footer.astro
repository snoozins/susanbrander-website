  >
    <p class="text-sm" style="color: var(--color-ink-muted)">
      &copy; {year} Susan Brander &mdash; Melbourne, Australia
    </p>

    <nav aria-label="Footer links" class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
