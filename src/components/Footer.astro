        href="https://www.linkedin.com/in/susan-brander/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium"
      >
        LinkedIn
      </a>
      <a
        href="https://techleadingladies.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium"
